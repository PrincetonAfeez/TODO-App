# Copy to .env and adjust. Loaded automatically by config/settings/base.py when present.
# Development defaults work without this file (SQLite, DEBUG=True).

# DJANGO_SETTINGS_MODULE=config.settings.dev
# SECRET_KEY=change-me-in-production
# DEBUG=True
# ALLOWED_HOSTS=127.0.0.1,localhost

# Production — set these in .env on the host (loaded by config/wsgi.py and config/asgi.py):
# DJANGO_SETTINGS_MODULE=config.settings.prod
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
# SECRET_KEY=use-a-long-random-value
# ALLOWED_HOSTS=example.com,www.example.com
